generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 // url      = env("DATABASE_URL")
}

model NotaFiscal {
  id           Int       @id @default(autoincrement())
  numero       Int
  codigo       String
  chaveAcesso  String
  situacao     String
  dataEmissao  DateTime

  @@map("nota_fiscal")
}

model Empresa {
  id          Int       @id @default(autoincrement())
  cnpj        String
  nome        String
  viabilidade String?
  uf          String?
  municipio   String?
  dataInicio  DateTime? @map("data_inicio")
  dataFim     DateTime? @map("data_fim")
  createdAt   DateTime  @default(now()) @map("created_at")
  excluidoAt  DateTime? @map("excluido_at")

  planoContas         PlanoContas[]
  lancamentos         Lancamento[]
  travaContabil       TravaContabil[]
  certificados        CertificadoDigital[]
  ecdArquivos         EcdArquivo[]
  spedEntregas        SpedEntrega[]
  auditLogs           AuditLog[]

  @@map("empresa")
}

model PlanoContas {
  id                 Int       @id @default(autoincrement())
  empresaId          Int?      @map("empresa_id")
  codigo             String
  descricao          String
  tipo               String
  natureza           String?
  grupo              String?
  dreGrupo           String?   @map("dre_grupo")
  subgrupo           String?
  fluxoCaixaTipo     String?   @map("fluxo_caixa_tipo")
  nivel              Int
  contaPaiId         Int?      @map("conta_pai_id")
  codigoReferencial  String?   @map("codigo_referencial")
  aceitaLancamento   Int       @default(1) @map("aceita_lancamento")
  createdAt          DateTime  @default(now()) @map("created_at")
  excluidoAt         DateTime? @map("excluido_at")

  empresa            Empresa?  @relation(fields: [empresaId], references: [id])
  contaPai           PlanoContas? @relation("PlanoContasHierarchy", fields: [contaPaiId], references: [id])
  subcontas          PlanoContas[] @relation("PlanoContasHierarchy")

  lancamentoItems    LancamentoItem[]
  mapaDemonstracoes  MapaDemonstracoes[]
  spedMappings       SpedMapping[]

  @@map("plano_contas")
}

model Lancamento {
  id          Int       @id @default(autoincrement())
  empresaId   Int?      @map("empresa_id")
  data        DateTime
  numero      String?
  historico   String?
  tipo        String    @default("N")
  createdAt   DateTime  @default(now()) @map("created_at")
  excluidoAt  DateTime? @map("excluido_at")

  empresa      Empresa?          @relation(fields: [empresaId], references: [id])
  itens        LancamentoItem[]

  @@index([data], map: "idx_lancamento_data")
  @@map("lancamento")
}

model LancamentoItem {
  id             Int       @id @default(autoincrement())
  lancamentoId   Int?      @map("lancamento_id")
  contaId        Int?      @map("conta_id")
  tipo           String
  valor          Float
  excluidoAt     DateTime? @map("excluido_at")

  lancamento     Lancamento?  @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  conta          PlanoContas? @relation(fields: [contaId], references: [id])

  @@index([contaId], map: "idx_lancamento_item_conta")
  @@map("lancamento_item")
}

model MapaDemonstracoes {
  id          Int       @id @default(autoincrement())
  contaId     Int?      @map("conta_id")
  tipo        String?
  categoria   String?
  excluidoAt  DateTime? @map("excluido_at")

  conta       PlanoContas? @relation(fields: [contaId], references: [id])

  @@map("mapa_demonstracoes")
}

model SpedMapping {
  id          String   @id
  contaId     Int      @map("conta_id")
  spedCode    String   @map("sped_code")
  description String?

  conta       PlanoContas @relation(fields: [contaId], references: [id])

  @@map("sped_mappings")
}

model Usuario {
  id            String    @id
  nome          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  isActive      Int       @default(1) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  auditLogs               AuditLog[]
  travasFechadas          TravaContabil[]
  ecdArquivosGerados      EcdArquivo[]
  assinaturasDigitais     AssinaturaDigital[]

  @@map("usuarios")
}

model AuditLog {
  id          String    @id
  companyId   Int?      @map("company_id")
  userId      String?   @map("user_id")
  entityName  String?   @map("entity_name")
  entityId    String?   @map("entity_id")
  action      String?
  oldData     String?   @map("old_data")
  newData     String?   @map("new_data")
  createdAt   DateTime  @default(now()) @map("created_at")

  empresa     Empresa?  @relation(fields: [companyId], references: [id])
  usuario     Usuario?  @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model TravaContabil {
  id          String    @id
  empresaId   Int       @map("empresa_id")
  year        Int
  month       Int
  isClosed    Int       @default(0) @map("is_closed")
  closedBy    String?   @map("closed_by")
  closedAt    DateTime? @map("closed_at")

  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  usuario     Usuario?  @relation(fields: [closedBy], references: [id])

  @@unique([empresaId, year, month])
  @@map("trava_contabil")
}

model CertificadoDigital {
  id               String    @id
  empresaId        Int       @map("empresa_id")
  certificateName  String?   @map("certificate_name")
  serialNumber     String?   @map("serial_number")
  validFrom        DateTime? @map("valid_from")
  validUntil       DateTime? @map("valid_until")
  issuer           String?
  encryptedPfx     Bytes?    @map("encrypted_pfx")
  createdAt        DateTime  @default(now()) @map("created_at")

  empresa          Empresa   @relation(fields: [empresaId], references: [id])

  assinaturas      AssinaturaDigital[]

  @@map("certificados_digitais")
}

model EcdArquivo {
  id             String    @id
  empresaId      Int       @map("empresa_id")
  fiscalYear     Int       @map("fiscal_year")
  fileName       String?   @map("file_name")
  fileHash       String?   @map("file_hash")
  generatedBy    String?   @map("generated_by")
  generatedAt    DateTime  @default(now()) @map("generated_at")
  signedAt       DateTime? @map("signed_at")
  deliveredAt    DateTime? @map("delivered_at")
  status         String?

  empresa        Empresa   @relation(fields: [empresaId], references: [id])
  usuario        Usuario?  @relation(fields: [generatedBy], references: [id])

  assinaturas    AssinaturaDigital[]

  @@map("ecd_arquivos")
}

model AssinaturaDigital {
  id              String    @id
  ecdArquivoId    String    @map("ecd_arquivo_id")
  signedBy        String?   @map("signed_by")
  certificateId   String?   @map("certificate_id")
  signatureHash   String    @map("signature_hash")
  signedAt        DateTime  @default(now()) @map("signed_at")

  ecdArquivo      EcdArquivo         @relation(fields: [ecdArquivoId], references: [id])
  usuario         Usuario?           @relation(fields: [signedBy], references: [id])
  certificado     CertificadoDigital? @relation(fields: [certificateId], references: [id])

  @@map("assinaturas_digitais")
}

model SpedEntrega {
  id             String    @id
  empresaId      Int       @map("empresa_id")
  spedType       String?   @map("sped_type")
  fiscalYear     Int?      @map("fiscal_year")
  protocol       String?
  receiptNumber  String?   @map("receipt_number")
  deliveredAt    DateTime? @map("delivered_at")
  status         String?

  empresa        Empresa   @relation(fields: [empresaId], references: [id])

  @@map("sped_entregas")
}

model Job {
  id           String    @id
  queueName    String?   @map("queue_name")
  payload      String?
  status       String    @default("PENDING")
  retries      Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  processedAt  DateTime? @map("processed_at")

  @@map("jobs")
}